# Aphrodite environment example.
# Copy to a private env file before starting a service. Do not commit real secrets.

APHRODITE_HOST=127.0.0.1
APHRODITE_PORT=9079
APHRODITE_MODULES=image_gen,skillopt,acp_relay

# Comma-separated browser origins allowed to call the HTTP API cross-origin.
# Leave empty to disable CORS (loopback-only). Use * to allow any origin
# (credentials are disabled when * is used).
APHRODITE_CORS_ORIGINS=

# Approved public HTTPS origin used by endpoint-preflight.
# Do not include /discord/interactions; Aphrodite appends that path.
APHRODITE_PUBLIC_BASE_URL=https://<approved-host>

# Required only for production Discord HTTP interactions at /discord/interactions.
# Use the Discord application public key, not the bot token.
APHRODITE_DISCORD_PUBLIC_KEY=

# Optional outbound Discord REST token for read-only live-publish preflight.
# Kept separate from APHRODITE_DISCORD_PUBLIC_KEY, which verifies inbound interactions.
APHRODITE_DISCORD_BOT_TOKEN=

# Optional live-publish preflight identity/channel assertions. These let the
# preflight prove the token belongs to the expected bot and can read the target
# channels without creating/editing/pinning messages.
APHRODITE_DISCORD_EXPECTED_BOT_ID=
APHRODITE_DISCORD_EXPECTED_BOT_USERNAME=

# Image generation model override.
APHRODITE_IMAGE_GEN_MODEL=gpt-image-2-medium

# ACP relay defaults. By default the relay uses the Hermes profile's own
# configured model/provider. Uncomment to force a specific engine instead.
APHRODITE_ACP_PROFILE=forge
# APHRODITE_ACP_PROVIDER=openrouter
# APHRODITE_ACP_MODEL=openai/gpt-4o-mini
APHRODITE_ACP_TURN_TIMEOUT=240.0
